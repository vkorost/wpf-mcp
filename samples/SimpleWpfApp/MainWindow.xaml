<Window x:Class="SimpleWpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Simple WPF Demo App" Height="400" Width="600"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Simple WPF Demo App"
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,15"
                   HorizontalAlignment="Center"/>

        <!-- Input row -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox x:Name="InputBox" Width="350" Height="28"
                     VerticalContentAlignment="Center" Margin="0,0,10,0"
                     Text="Enter text here..."/>
            <Button x:Name="SubmitButton" Content="Submit"
                    Width="80" Height="28" Click="SubmitButton_Click"/>
        </StackPanel>

        <!-- Checkbox -->
        <CheckBox x:Name="AgreeCheckbox" Grid.Row="2"
                  Content="I agree to the terms" Margin="0,0,0,10"/>

        <!-- ComboBox -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Favorite color:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <ComboBox x:Name="ColorCombo" Width="150" Height="28">
                <ComboBoxItem Content="Red"/>
                <ComboBoxItem Content="Green"/>
                <ComboBoxItem Content="Blue"/>
            </ComboBox>
        </StackPanel>

        <!-- Menu -->
        <Menu Grid.Row="4" Margin="0,0,0,10">
            <MenuItem Header="_File">
                <MenuItem Header="_New" x:Name="MenuNew" Click="MenuNew_Click"/>
                <MenuItem Header="_Open" x:Name="MenuOpen" Click="MenuOpen_Click"/>
                <Separator/>
                <MenuItem Header="E_xit" x:Name="MenuExit" Click="MenuExit_Click"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About" x:Name="MenuAbout" Click="MenuAbout_Click"/>
            </MenuItem>
        </Menu>

        <!-- ListBox -->
        <ListBox x:Name="ItemList" Grid.Row="5" Margin="0,0,0,10">
            <ListBoxItem Content="Apple"/>
            <ListBoxItem Content="Banana"/>
            <ListBoxItem Content="Cherry"/>
            <ListBoxItem Content="Date"/>
            <ListBoxItem Content="Elderberry"/>
        </ListBox>

        <!-- Status bar -->
        <TextBlock x:Name="StatusText" Grid.Row="6" Text="Ready"
                   FontStyle="Italic" Foreground="Gray"/>
    </Grid>
</Window>
